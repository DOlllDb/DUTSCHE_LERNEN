# Copy relevant values into apps/api/.env for local dev, and into
# /etc/vocab-app/api.env (chmod 640) on the server for production.

NODE_ENV=development
PORT=3000
DB_PATH=./data/vocab.db

# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
COOKIE_SECRET=

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Origin(s) allowed to call the API from a browser (the web app's URL)
CORS_ORIGIN=http://localhost:5173

# Set to true only once the site is served over HTTPS -- browsers silently
# drop Secure cookies over plain HTTP, so this must stay false for an
# IP-only/HTTP deploy even in production.
COOKIE_SECURE=false

# Public URL the app is served at -- used to build the link in verification emails.
APP_ORIGIN=http://localhost:5173

# SMTP is optional: leave unset to have verification links logged to the
# server console instead of emailed (useful for local dev). For Gmail:
# host=smtp.gmail.com, port=587, user=your Gmail address, pass=an App
# Password (Google Account -> Security -> 2-Step Verification -> App
# Passwords -- requires 2-Step Verification to be enabled first).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Deutsch Lernen <no-reply@deutsch-lernen.local>
